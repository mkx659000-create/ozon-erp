generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===================== AUTH & RBAC =====================

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  email        String     @unique
  passwordHash String     @map("password_hash")
  nickname     String?
  avatar       String?
  role         UserRole   @default(OPERATOR)
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  storeAccounts UserStoreAccount[]
  operationLogs OperationLog[]

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

// ===================== MULTI-STORE =====================

model StoreAccount {
  id           String      @id @default(uuid())
  storeName    String      @map("store_name")
  ozonClientId String      @map("ozon_client_id")
  ozonApiKey   String      @map("ozon_api_key")
  status       StoreStatus @default(ACTIVE)
  lastSyncAt   DateTime?   @map("last_sync_at")
  syncEnabled  Boolean     @default(true) @map("sync_enabled")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  users                UserStoreAccount[]
  products             Product[]
  promotions           Promotion[]
  orders               Order[]
  syncLogs             SyncLog[]
  financeTransactions  FinanceTransaction[]
  financeSummaries     FinanceSummary[]
  warehouses           Warehouse[]
  returns              Return[]
  sellerRatings        SellerRating[]

  @@map("store_accounts")
}

enum StoreStatus {
  ACTIVE
  DISABLED
  AUTH_EXPIRED
}

model UserStoreAccount {
  userId         String @map("user_id")
  storeAccountId String @map("store_account_id")

  user         User         @relation(fields: [userId], references: [id])
  storeAccount StoreAccount @relation(fields: [storeAccountId], references: [id])

  @@id([userId, storeAccountId])
  @@map("user_store_accounts")
}

// ===================== PRODUCTS =====================

model Product {
  id             String        @id @default(uuid())
  storeAccountId String        @map("store_account_id")
  ozonProductId  BigInt        @map("ozon_product_id")
  offerId        String?       @map("offer_id")
  name           String
  barcode        String?
  categoryId     Int?          @map("category_id")
  categoryName   String?       @map("category_name")
  notes          String?
  primaryImage   String?       @map("primary_image")
  images         String[]      @default([])
  status         ProductStatus @default(MODERATION)
  visible        Boolean       @default(true)

  sellingPrice  Decimal? @map("selling_price") @db.Decimal(12, 2)
  originalPrice Decimal? @map("original_price") @db.Decimal(12, 2)
  lowestPrice   Decimal? @map("lowest_price") @db.Decimal(12, 2)
  costPrice     Decimal? @map("cost_price") @db.Decimal(12, 2)
  currencyCode  String   @default("RUB") @map("currency_code")
  priceIndex    String?  @map("price_index")

  totalStock Int @default(0) @map("total_stock")
  sales14d   Int @default(0) @map("sales_14d")

  reviewCount Int      @default(0) @map("review_count")
  rating      Decimal? @db.Decimal(3, 2)

  weightGross     Decimal? @map("weight_gross") @db.Decimal(10, 2)
  dimensionLength Decimal? @map("dimension_length") @db.Decimal(10, 2)
  dimensionWidth  Decimal? @map("dimension_width") @db.Decimal(10, 2)
  dimensionHeight Decimal? @map("dimension_height") @db.Decimal(10, 2)
  volumeWeight    Decimal? @map("volume_weight") @db.Decimal(10, 2)

  mergeCount  Int     @default(0) @map("merge_count")
  mergeNumber String? @map("merge_number")

  ozonCreatedAt  DateTime? @map("ozon_created_at")
  ozonUpdatedAt  DateTime? @map("ozon_updated_at")
  lastModifiedAt DateTime? @map("last_modified_at")
  lastSyncAt     DateTime? @map("last_sync_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  storeAccount      StoreAccount       @relation(fields: [storeAccountId], references: [id])
  ozonFlags String[] @default([]) @map("ozon_flags")

  skus              ProductSku[]
  promotionProducts PromotionProduct[]
  priceRules        PriceAutoRule[]

  @@unique([storeAccountId, ozonProductId])
  @@index([storeAccountId, status])
  @@index([storeAccountId, name])
  @@map("products")
}

enum ProductStatus {
  ON_SALE
  OUT_OF_STOCK
  MODERATION
  MODERATION_FAILED
  REMOVED
  ARCHIVED
}

model ProductSku {
  id        String @id @default(uuid())
  productId String @map("product_id")
  ozonSku   BigInt @map("ozon_sku")
  fboSku    BigInt? @map("fbo_sku")
  fbsSku    BigInt? @map("fbs_sku")
  stock     Int    @default(0)
  reserved  Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, ozonSku])
  @@map("product_skus")
}

model PriceAutoRule {
  id        String        @id @default(uuid())
  productId String        @map("product_id")
  ruleType  PriceRuleType @map("rule_type")
  value     Decimal       @db.Decimal(10, 2)
  minPrice  Decimal?      @map("min_price") @db.Decimal(12, 2)
  maxPrice  Decimal?      @map("max_price") @db.Decimal(12, 2)
  enabled   Boolean       @default(true)
  createdAt DateTime      @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("price_auto_rules")
}

enum PriceRuleType {
  COST_PLUS_PERCENT
  COST_PLUS_FIXED
  COMPETITOR_MINUS
}

// ===================== PROMOTIONS =====================

model Promotion {
  id                String                     @id @default(uuid())
  storeAccountId    String                     @map("store_account_id")
  ozonActionId      BigInt                     @map("ozon_action_id")
  title             String
  description       String?
  startDate         DateTime                   @map("start_date")
  endDate           DateTime                   @map("end_date")
  status            PromotionStatus            @default(ACTIVE)
  participationType PromotionParticipationType @default(MANUAL) @map("participation_type")
  lastSyncAt        DateTime?                  @map("last_sync_at")
  createdAt         DateTime                   @default(now()) @map("created_at")
  updatedAt         DateTime                   @updatedAt @map("updated_at")

  storeAccount StoreAccount       @relation(fields: [storeAccountId], references: [id])
  products     PromotionProduct[]

  @@unique([storeAccountId, ozonActionId])
  @@index([storeAccountId, status])
  @@map("promotions")
}

enum PromotionStatus {
  ACTIVE
  UPCOMING
  ENDED
}

enum PromotionParticipationType {
  MANUAL
  AUTO
}

model PromotionProduct {
  id                  String              @id @default(uuid())
  promotionId         String              @map("promotion_id")
  productId           String              @map("product_id")
  participationStatus ParticipationStatus @default(NOT_JOINED) @map("participation_status")
  originalPrice       Decimal?            @map("original_price") @db.Decimal(12, 2)
  lowestPromoPrice    Decimal?            @map("lowest_promo_price") @db.Decimal(12, 2)
  promoPrice          Decimal?            @map("promo_price") @db.Decimal(12, 2)
  promoDiscount       Decimal?            @map("promo_discount") @db.Decimal(5, 2)
  promoStock          Int?                @map("promo_stock")
  operatorId          String?             @map("operator_id")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([promotionId, productId])
  @@map("promotion_products")
}

enum ParticipationStatus {
  JOINED
  NOT_JOINED
  EXITED
}

// ===================== ORDERS =====================

model Order {
  id                String      @id @default(uuid())
  storeAccountId    String      @map("store_account_id")
  ozonPostingNumber String      @map("ozon_posting_number")
  ozonOrderId       BigInt?     @map("ozon_order_id")
  orderType         String      @default("FBS") @map("order_type")
  orderStatus       OrderStatus @map("order_status")
  totalAmount       Decimal     @map("total_amount") @db.Decimal(12, 2)
  currencyCode      String      @default("RUB") @map("currency_code")
  shippingProvider  String?     @map("shipping_provider")
  trackingNumber    String?     @map("tracking_number")
  customerName      String?     @map("customer_name")
  customerRegion    String?     @map("customer_region")
  ozonCreatedAt     DateTime    @map("ozon_created_at")
  shipByDate        DateTime?   @map("ship_by_date")
  deliveredAt       DateTime?   @map("delivered_at")
  lastSyncAt        DateTime?   @map("last_sync_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  storeAccount StoreAccount @relation(fields: [storeAccountId], references: [id])
  items        OrderItem[]

  @@unique([storeAccountId, ozonPostingNumber])
  @@index([storeAccountId, orderStatus])
  @@index([ozonCreatedAt])
  @@map("orders")
}

enum OrderStatus {
  AWAITING_PACKAGING
  AWAITING_DELIVER
  DELIVERING
  DELIVERED
  CANCELLED
  RETURNED
}

model OrderItem {
  id      String  @id @default(uuid())
  orderId String  @map("order_id")
  ozonSku BigInt  @map("ozon_sku")
  name    String
  quantity Int
  price   Decimal @db.Decimal(12, 2)
  offerId String? @map("offer_id")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// ===================== CATEGORIES =====================

model Category {
  id          Int       @id
  parentId    Int?      @map("parent_id")
  name        String
  nameZh      String?   @map("name_zh")
  level       Int       @default(0)
  hasChildren Boolean   @default(false) @map("has_children")
  lastSyncAt  DateTime? @map("last_sync_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  @@map("categories")
}

// ===================== LOGS =====================

model SyncLog {
  id             String        @id @default(uuid())
  storeAccountId String        @map("store_account_id")
  syncType       SyncType      @map("sync_type")
  status         SyncLogStatus
  itemsProcessed Int           @default(0) @map("items_processed")
  itemsFailed    Int           @default(0) @map("items_failed")
  errorMessage   String?       @map("error_message")
  startedAt      DateTime      @map("started_at")
  completedAt    DateTime?     @map("completed_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  storeAccount StoreAccount @relation(fields: [storeAccountId], references: [id])

  @@index([storeAccountId, syncType, createdAt])
  @@map("sync_logs")
}

enum SyncType {
  PRODUCT
  PRICE
  STOCK
  PROMOTION
  ORDER
  CATEGORY
  ANALYTICS
  FINANCE
  RETURNS
  WAREHOUSE
  RATING
}

enum SyncLogStatus {
  RUNNING
  SUCCESS
  PARTIAL_FAILURE
  FAILED
}

model OperationLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  targetType String   @map("target_type")
  targetId   String?  @map("target_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([targetType, targetId])
  @@map("operation_logs")
}

// ===================== FINANCE =====================

model FinanceTransaction {
  id               String   @id @default(uuid())
  storeAccountId   String   @map("store_account_id")
  operationId      BigInt   @map("operation_id")
  operationType    String   @map("operation_type")
  operationDate    DateTime @map("operation_date")
  postingNumber    String?  @map("posting_number")
  amount           Decimal  @db.Decimal(12, 2)
  commissionAmount Decimal? @map("commission_amount") @db.Decimal(12, 2)
  deliveryCharge   Decimal? @map("delivery_charge") @db.Decimal(12, 2)
  accruals         Decimal? @db.Decimal(12, 2)
  ozonSku          BigInt?  @map("ozon_sku")
  productName      String?  @map("product_name")
  rawData          Json?    @map("raw_data")
  createdAt        DateTime @default(now()) @map("created_at")

  storeAccount StoreAccount @relation(fields: [storeAccountId], references: [id])

  @@unique([storeAccountId, operationId])
  @@index([storeAccountId, operationDate])
  @@index([storeAccountId, operationType])
  @@map("finance_transactions")
}

model FinanceSummary {
  id               String   @id @default(uuid())
  storeAccountId   String   @map("store_account_id")
  date             DateTime @db.Date
  totalSales       Decimal  @default(0) @map("total_sales") @db.Decimal(14, 2)
  totalCommissions Decimal  @default(0) @map("total_commissions") @db.Decimal(14, 2)
  totalDelivery    Decimal  @default(0) @map("total_delivery") @db.Decimal(14, 2)
  totalReturns     Decimal  @default(0) @map("total_returns") @db.Decimal(14, 2)
  totalPayout      Decimal  @default(0) @map("total_payout") @db.Decimal(14, 2)
  transactionCount Int      @default(0) @map("transaction_count")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  storeAccount StoreAccount @relation(fields: [storeAccountId], references: [id])

  @@unique([storeAccountId, date])
  @@map("finance_summaries")
}

// ===================== WAREHOUSES =====================

model Warehouse {
  id              String @id @default(uuid())
  storeAccountId  String @map("store_account_id")
  ozonWarehouseId BigInt @map("ozon_warehouse_id")
  name            String
  isRfbs          Boolean @default(false) @map("is_rfbs")
  status          String
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  storeAccount StoreAccount @relation(fields: [storeAccountId], references: [id])

  @@unique([storeAccountId, ozonWarehouseId])
  @@map("warehouses")
}

// ===================== RETURNS =====================

model Return {
  id             String   @id @default(uuid())
  storeAccountId String   @map("store_account_id")
  ozonReturnId   BigInt   @map("ozon_return_id")
  postingNumber  String?  @map("posting_number")
  returnType     String   @map("return_type")
  status         String
  ozonSku        BigInt?  @map("ozon_sku")
  productName    String?  @map("product_name")
  quantity       Int      @default(1)
  returnReason   String?  @map("return_reason")
  returnAmount   Decimal? @map("return_amount") @db.Decimal(12, 2)
  commission     Decimal? @db.Decimal(12, 2)
  returnedAt     DateTime? @map("returned_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  storeAccount StoreAccount @relation(fields: [storeAccountId], references: [id])

  @@unique([storeAccountId, ozonReturnId, returnType])
  @@index([storeAccountId, status])
  @@index([storeAccountId, returnType])
  @@map("returns")
}

// ===================== SELLER RATING =====================

model SellerRating {
  id             String   @id @default(uuid())
  storeAccountId String   @map("store_account_id")
  ratingGroup    String   @map("rating_group")
  ratingName     String   @map("rating_name")
  currentValue   Decimal  @map("current_value") @db.Decimal(5, 2)
  pastValue      Decimal  @map("past_value") @db.Decimal(5, 2)
  ratingStatus   String   @map("rating_status")
  penalty        Boolean  @default(false)
  recordDate     DateTime @db.Date @map("record_date")
  createdAt      DateTime @default(now()) @map("created_at")

  storeAccount StoreAccount @relation(fields: [storeAccountId], references: [id])

  @@unique([storeAccountId, ratingGroup, ratingName, recordDate])
  @@index([storeAccountId, recordDate])
  @@map("seller_ratings")
}
