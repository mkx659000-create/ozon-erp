# Database
DATABASE_URL="postgresql://ozon_erp:ozon_erp_password@localhost:5432/ozon_erp?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption key for Ozon API keys (AES-256-GCM)
ENCRYPTION_KEY=change-this-to-a-32-byte-hex-string-in-production

# Server
SERVER_PORT=3000

# Frontend
VITE_API_BASE_URL=http://localhost:3000/api
